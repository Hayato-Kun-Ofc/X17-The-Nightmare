  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "=== STALK STATE (Creeping deep in the fog) ===",
          "Sensor": {
            "Type": "State",
            "State": "Stalk"
          },
          "Instructions": [
            {
              "$Comment": "Creepy stalk sound on entry",
              "Continue": true,
              "Sensor": {
                "Once": true,
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlaySound",
                  "SoundEventId": "SFX_X_17_Stalk"
                }
              ]
            },
            {
              "$Comment": "Occasional creepy stalk sounds while stalking",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    20,
                    60
                  ],
                  "Action": {
                    "Type": "PlaySound",
                    "SoundEventId": "SFX_X_17_Stalk"
                  }
                }
              ]
            },
            {
              "$Comment": "Maintain 70 block distance creeping slowly",
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": {
                  "Compute": "ViewRange"
                },
                "LockOnTarget": true
              },
              "HeadMotion": {
                "Type": "Watch"
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 0.15,
                "SlowDownDistance": 75,
                "StopDistance": 70
              }
            },
            {
              "$Comment": "If Player gets too close (25 blocks) -> 90% Vanish / 10% Rage",
              "Type": "Random",
              "Sensor": {
                "Type": "Player",
                "Range": 25
              },
              "Instructions": [
                {
                  "Weight": 90,
                  "Sensor": {
                    "Type": "Any"
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": "Vanish"
                    }
                  ]
                },
                {
                  "Weight": 10,
                  "Sensor": {
                    "Type": "Any"
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": "Rage"
                    }
                  ]
                }
              ]
            },
            {
              "$Comment": "Alternatively, if he stalks for too long without being noticed -> Rage",
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    45,
                    90
                  ],
                  "Action": {
                    "Type": "State",
                    "State": "Rage"
                  }
                }
              ]
            }
          ]
        },
        {
          "$Comment": "=== VANISH STATE (Terrifying Disappearance) ===",
          "Sensor": {
            "Type": "State",
            "State": "Vanish"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Once": true,
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlaySound",
                  "SoundEventId": "SFX_X_17_Alerted"
                },
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    1.5,
                    1.5
                  ],
                  "Action": {
                    "Type": "Despawn"
                  }
                }
              ]
            }
          ]
        },
        {
          "$Comment": "=== RAGE STATE (High-Speed Chase Phase) ===",
          "Sensor": {
            "Type": "State",
            "State": "Rage"
          },
          "Instructions": [
            {
              "$Comment": "Jumpscare Sound on entry",
              "Continue": true,
              "Sensor": {
                "Once": true,
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                },
                {
                  "Type": "PlaySound",
                  "SoundEventId": "SFX_X_17_Jumpscare"
                }
              ]
            },
            {
              "$Comment": "Aggressive roaring loop while chasing",
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    2,
                    4
                  ],
                  "Action": {
                    "Type": "PlaySound",
                    "SoundEventId": "SFX_X_17_Rage"
                  }
                }
              ]
            },
            {
              "$Comment": "Direct brutal melee attack - NO dodging, NO strafing",
              "Reference": "Component_Instruction_Target_Adjusted_Attack_Melee",
              "Modify": {
                "AttackSequence": {
                  "Compute": "AttackSequence"
                },
                "AttackDistance": {
                  "Compute": "AttackDistance"
                },
                "CombatRelativeTurnSpeed": {
                  "Compute": "CombatRelativeTurnSpeed"
                },
                "MaintainDistance": false,
                "StrafingDurationRange": [
                  0,
                  0
                ],
                "StrafingFrequencyRange": [
                  999,
                  999
                ]
              }
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Player",
                "Range": {
                  "Compute": "AlertedRange"
                },
                "LockOnTarget": true
              },
              "HeadMotion": {
                "Type": "Watch"
              },
              "BodyMotion": {
                "Type": "Seek",
                "RelativeSpeed": 1.0,
                "SlowDownDistance": 1.5,
                "StopDistance": 0.5
              }
            },
            {
              "$Comment": "SURVIVAL: If player kites him for 45s, he vanishes",
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    45,
                    45
                  ],
                  "Action": {
                    "Type": "State",
                    "State": "Vanish"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  }
}
